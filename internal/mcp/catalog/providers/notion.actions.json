{
  "display_name": "Notion",
  "resources": {
    "page": {
      "display_name": "Pages",
      "description": "Notion pages the AI can access",
      "id_field": "id",
      "name_field": "title",
      "icon": "page",
      "list_action": "/v1/search",
      "request_config": {
        "method": "POST",
        "headers": {
          "Notion-Version": "2022-06-28"
        },
        "body_template": {
          "filter": {
            "value": "page",
            "property": "object"
          },
          "page_size": 100
        },
        "response_path": "results"
      }
    },
    "database": {
      "display_name": "Databases",
      "description": "Notion databases the AI can query",
      "id_field": "id",
      "name_field": "title",
      "icon": "database",
      "list_action": "/v1/search",
      "request_config": {
        "method": "POST",
        "headers": {
          "Notion-Version": "2022-06-28"
        },
        "body_template": {
          "filter": {
            "value": "database",
            "property": "object"
          },
          "page_size": 100
        },
        "response_path": "results"
      }
    }
  },
  "actions": {
    "search": {
      "display_name": "Search",
      "description": "Search pages and databases in Notion",
      "resource_type": "",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query"
          },
          "page_size": {
            "type": "integer",
            "description": "Max results"
          }
        }
      },
      "execution": {
        "method": "POST",
        "path": "/v1/search",
        "body_mapping": {
          "query": "query",
          "page_size": "page_size"
        },
        "headers": {
          "Notion-Version": "2022-06-28"
        },
        "response_path": "results"
      }
    },
    "get_page": {
      "display_name": "Get Page",
      "description": "Retrieve a Notion page",
      "resource_type": "page",
      "parameters": {
        "type": "object",
        "properties": {
          "page_id": {
            "type": "string",
            "description": "Page ID"
          }
        },
        "required": [
          "page_id"
        ]
      },
      "execution": {
        "method": "GET",
        "path": "/v1/pages/{page_id}",
        "headers": {
          "Notion-Version": "2022-06-28"
        }
      }
    },
    "query_database": {
      "display_name": "Query Database",
      "description": "Query a Notion database",
      "resource_type": "database",
      "parameters": {
        "type": "object",
        "properties": {
          "database_id": {
            "type": "string",
            "description": "Database ID"
          },
          "page_size": {
            "type": "integer",
            "description": "Max results"
          }
        },
        "required": [
          "database_id"
        ]
      },
      "execution": {
        "method": "POST",
        "path": "/v1/databases/{database_id}/query",
        "body_mapping": {
          "page_size": "page_size"
        },
        "headers": {
          "Notion-Version": "2022-06-28"
        },
        "response_path": "results"
      }
    }
  }
}
