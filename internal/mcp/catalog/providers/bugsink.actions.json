    "events_list": {
      "display_name": "Events List",
      "description": "LIST requires: ?issue=\u003cuuid\u003e Optional: ?order=asc|desc (default: desc) LIST omits `data`, ordered by digest_order RETRIEVE includes `data` (pure PK lookup; no filters/order applied)",
      "access": "read",
      "resource_type": "",
      "parameters": {
        "properties": {
          "cursor": {
            "type": "string",
            "description": "The pagination cursor value."
          },
          "issue": {
            "type": "string",
            "description": "Filter events by issue UUID (required)."
          },
          "order": {
            "type": "string",
            "description": "Sort order of digest_order (default: desc)."
          }
        },
        "type": "object"
      },
      "execution": {
        "method": "GET",
        "path": "/api/canonical/0/events/",
        "query_mapping": {
          "cursor": "cursor",
          "issue": "issue",
          "order": "order"
        },
        "response_path": "results"
      },
      "response_schema": "PaginatedEventListList"
    },
    "events_retrieve": {
