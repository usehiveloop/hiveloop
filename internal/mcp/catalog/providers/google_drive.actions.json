{
  "display_name": "Google Drive",
  "resources": {
    "folder": {
      "display_name": "Folders",
      "description": "Folders the AI can access files within",
      "id_field": "id",
      "name_field": "name",
      "icon": "folder",
      "list_action": "/drive/v3/files",
      "request_config": {
        "method": "GET",
        "query_params": {
          "q": "mimeType='application/vnd.google-apps.folder' and trashed=false",
          "spaces": "drive",
          "fields": "files(id,name)",
          "pageSize": "100"
        },
        "response_path": "files"
      }
    }
  },
  "actions": {
    "list_files": {
      "display_name": "List Files",
      "description": "List files in Google Drive",
      "resource_type": "",
      "parameters": {
        "type": "object",
        "properties": {
          "page_size": {
            "type": "integer",
            "description": "Max results"
          },
          "q": {
            "type": "string",
            "description": "Search query"
          }
        }
      },
      "execution": {
        "method": "GET",
        "path": "/drive/v3/files",
        "query_mapping": {
          "pageSize": "page_size",
          "q": "q"
        },
        "response_path": "files"
      }
    },
    "list_events": {
      "display_name": "List Events",
      "description": "List calendar events",
      "resource_type": "calendar",
      "parameters": {
        "type": "object",
        "properties": {
          "calendar_id": {
            "type": "string",
            "description": "Calendar ID"
          },
          "max_results": {
            "type": "integer",
            "description": "Max events"
          }
        },
        "required": [
          "calendar_id"
        ]
      },
      "execution": {
        "method": "GET",
        "path": "/calendar/v3/calendars/{calendar_id}/events",
        "query_mapping": {
          "maxResults": "max_results"
        }
      }
    }
  }
}
