{
  "display_name": "Slack",
  "resources": {
    "slack_thread": {
      "display_name": "Slack Threads",
      "description": "A threaded conversation in a Slack channel. Identified by (team, channel, thread_ts). Continuation happens at the thread level — every event in the same thread routes into the same agent conversation.",
      "id_field": "thread_ts",
      "name_field": "thread_ts",
      "icon": "comment-discussion",
      "list_action": "/conversations.list",
      "request_config": {
        "method": "POST",
        "body_template": {
          "exclude_archived": true,
          "limit": 1000,
          "types": "public_channel,private_channel,im,mpim"
        },
        "response_path": "channels"
      },
      "ref_bindings": {
        "channel": "$refs.channel_id",
        "ts": "$refs.thread_id"
      },
      "resource_key_template": "slack:$refs.team_id:$refs.channel_id:$refs.thread_id"
    },
    "slack_channel": {
      "display_name": "Slack Channels",
      "description": "A Slack channel, private group, DM, or multi-party DM. Channel-level events (member joined, channel created) use this resource. No resource_key_template — these events don't naturally continue a conversation.",
      "id_field": "id",
      "name_field": "name_normalized",
      "icon": "hash",
      "list_action": "/conversations.list",
      "request_config": {
        "method": "POST",
        "body_template": {
          "exclude_archived": true,
          "limit": 1000,
          "types": "public_channel,private_channel"
        },
        "response_path": "channels"
      },
      "ref_bindings": {
        "channel": "$refs.channel_id"
      }
    },
    "slack_user": {
      "display_name": "Slack Users",
      "description": "A member of a Slack workspace. Used for context actions that look up user information by ID.",
      "id_field": "id",
      "name_field": "real_name",
      "icon": "person",
      "list_action": "/users.list",
      "request_config": {
        "method": "POST",
        "body_template": {
          "limit": 1000
        },
        "response_path": "members"
      },
      "ref_bindings": {
        "user": "$refs.user"
      }
    }
  },

  "actions": {
    "conversations_history": {
      "display_name": "Get channel history",
      "description": "Fetch recent messages from a public or private channel, DM, or multi-party DM. Returns up to 1000 messages. Use 'oldest' and 'latest' cursors for pagination.",
      "access": "read",
      "resource_type": "slack_thread",
      "parameters": {
        "type": "object",
        "properties": {
          "channel": {"type": "string", "description": "Conversation ID (C/D/G...)"},
          "cursor": {"type": "string", "description": "Pagination cursor from previous response"},
          "inclusive": {"type": "boolean", "description": "Include messages at the latest/oldest boundary"},
          "latest": {"type": "string", "description": "End of time range (inclusive) as Slack ts"},
          "oldest": {"type": "string", "description": "Start of time range (inclusive) as Slack ts"},
          "limit": {"type": "integer", "description": "Max messages to return (default 100, max 1000)"}
        },
        "required": ["channel"]
      },
      "execution": {
        "method": "POST",
        "path": "/conversations.history",
        "headers": {"Content-Type": "application/json; charset=utf-8"},
        "body_mapping": {
          "channel": "channel",
          "cursor": "cursor",
          "inclusive": "inclusive",
          "latest": "latest",
          "oldest": "oldest",
          "limit": "limit"
        },
        "response_path": "messages"
      },
      "response_schema": "conversations_history_response"
    },

    "conversations_replies": {
      "display_name": "Get thread replies",
      "description": "Fetch a thread and all its replies. 'ts' is the parent message's timestamp. Returns the parent plus every reply in chronological order.",
      "access": "read",
      "resource_type": "slack_thread",
      "parameters": {
        "type": "object",
        "properties": {
          "channel": {"type": "string", "description": "Conversation ID"},
          "ts": {"type": "string", "description": "Timestamp of the parent message (thread root)"},
          "cursor": {"type": "string"},
          "limit": {"type": "integer"},
          "inclusive": {"type": "boolean"},
          "latest": {"type": "string"},
          "oldest": {"type": "string"}
        },
        "required": ["channel", "ts"]
      },
      "execution": {
        "method": "POST",
        "path": "/conversations.replies",
        "headers": {"Content-Type": "application/json; charset=utf-8"},
        "body_mapping": {
          "channel": "channel",
          "ts": "ts",
          "cursor": "cursor",
          "limit": "limit",
          "inclusive": "inclusive",
          "latest": "latest",
          "oldest": "oldest"
        },
        "response_path": "messages"
      },
      "response_schema": "conversations_replies_response"
    },

    "conversations_info": {
      "display_name": "Get channel info",
      "description": "Fetch metadata about a channel: name, topic, purpose, creator, members count, etc.",
      "access": "read",
      "resource_type": "slack_channel",
      "parameters": {
        "type": "object",
        "properties": {
          "channel": {"type": "string"},
          "include_locale": {"type": "boolean"},
          "include_num_members": {"type": "boolean"}
        },
        "required": ["channel"]
      },
      "execution": {
        "method": "POST",
        "path": "/conversations.info",
        "headers": {"Content-Type": "application/json; charset=utf-8"},
        "body_mapping": {
          "channel": "channel",
          "include_locale": "include_locale",
          "include_num_members": "include_num_members"
        },
        "response_path": "channel"
      },
      "response_schema": "conversations_info_response"
    },

    "conversations_list": {
      "display_name": "List channels",
      "description": "List channels the bot can access in the workspace. Supports filtering by channel type and archive state.",
      "access": "read",
      "resource_type": "slack_channel",
      "parameters": {
        "type": "object",
        "properties": {
          "cursor": {"type": "string"},
          "exclude_archived": {"type": "boolean"},
          "limit": {"type": "integer"},
          "types": {"type": "string", "description": "Comma-separated: public_channel,private_channel,mpim,im"}
        }
      },
      "execution": {
        "method": "POST",
        "path": "/conversations.list",
        "headers": {"Content-Type": "application/json; charset=utf-8"},
        "body_mapping": {
          "cursor": "cursor",
          "exclude_archived": "exclude_archived",
          "limit": "limit",
          "types": "types"
        },
        "response_path": "channels"
      },
      "response_schema": "conversations_list_response"
    },

    "conversations_members": {
      "display_name": "List channel members",
      "description": "List user IDs of members in a channel.",
      "access": "read",
      "resource_type": "slack_channel",
      "parameters": {
        "type": "object",
        "properties": {
          "channel": {"type": "string"},
          "cursor": {"type": "string"},
          "limit": {"type": "integer"}
        },
        "required": ["channel"]
      },
      "execution": {
        "method": "POST",
        "path": "/conversations.members",
        "headers": {"Content-Type": "application/json; charset=utf-8"},
        "body_mapping": {
          "channel": "channel",
          "cursor": "cursor",
          "limit": "limit"
        },
        "response_path": "members"
      },
      "response_schema": "conversations_members_response"
    },

    "users_info": {
      "display_name": "Get user info",
      "description": "Fetch detailed information about a user by ID: profile, real name, email, timezone, etc.",
      "access": "read",
      "resource_type": "slack_user",
      "parameters": {
        "type": "object",
        "properties": {
          "user": {"type": "string", "description": "User ID (U...)"},
          "include_locale": {"type": "boolean"}
        },
        "required": ["user"]
      },
      "execution": {
        "method": "POST",
        "path": "/users.info",
        "headers": {"Content-Type": "application/json; charset=utf-8"},
        "body_mapping": {
          "user": "user",
          "include_locale": "include_locale"
        },
        "response_path": "user"
      },
      "response_schema": "users_info_response"
    },

    "users_list": {
      "display_name": "List users",
      "description": "List all users in the workspace. Supports pagination via cursor.",
      "access": "read",
      "resource_type": "slack_user",
      "parameters": {
        "type": "object",
        "properties": {
          "cursor": {"type": "string"},
          "limit": {"type": "integer"},
          "include_locale": {"type": "boolean"}
        }
      },
      "execution": {
        "method": "POST",
        "path": "/users.list",
        "headers": {"Content-Type": "application/json; charset=utf-8"},
        "body_mapping": {
          "cursor": "cursor",
          "limit": "limit",
          "include_locale": "include_locale"
        },
        "response_path": "members"
      },
      "response_schema": "users_list_response"
    },

    "users_lookup_by_email": {
      "display_name": "Find user by email",
      "description": "Look up a workspace user by their email address.",
      "access": "read",
      "resource_type": "slack_user",
      "parameters": {
        "type": "object",
        "properties": {
          "email": {"type": "string"}
        },
        "required": ["email"]
      },
      "execution": {
        "method": "POST",
        "path": "/users.lookupByEmail",
        "headers": {"Content-Type": "application/json; charset=utf-8"},
        "body_mapping": {"email": "email"},
        "response_path": "user"
      },
      "response_schema": "users_info_response"
    },

    "search_messages": {
      "display_name": "Search messages",
      "description": "Full-text search across workspace messages. Query supports operators like 'in:#channel', 'from:@user', 'has:link'.",
      "access": "read",
      "resource_type": "",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {"type": "string"},
          "sort": {"type": "string", "description": "score or timestamp"},
          "sort_dir": {"type": "string", "description": "asc or desc"},
          "count": {"type": "integer"},
          "page": {"type": "integer"}
        },
        "required": ["query"]
      },
      "execution": {
        "method": "POST",
        "path": "/search.messages",
        "headers": {"Content-Type": "application/json; charset=utf-8"},
        "body_mapping": {
          "query": "query",
          "sort": "sort",
          "sort_dir": "sort_dir",
          "count": "count",
          "page": "page"
        },
        "response_path": "messages.matches"
      },
      "response_schema": "search_messages_response"
    },

    "reactions_get": {
      "display_name": "Get reactions on a message",
      "description": "List all reactions on a specific message.",
      "access": "read",
      "resource_type": "",
      "parameters": {
        "type": "object",
        "properties": {
          "channel": {"type": "string"},
          "timestamp": {"type": "string", "description": "Message ts"},
          "full": {"type": "boolean"}
        },
        "required": ["channel", "timestamp"]
      },
      "execution": {
        "method": "POST",
        "path": "/reactions.get",
        "headers": {"Content-Type": "application/json; charset=utf-8"},
        "body_mapping": {
          "channel": "channel",
          "timestamp": "timestamp",
          "full": "full"
        },
        "response_path": "message.reactions"
      },
      "response_schema": "reactions_get_response"
    },

    "team_info": {
      "display_name": "Get workspace info",
      "description": "Fetch information about the current Slack workspace: name, domain, icon, etc.",
      "access": "read",
      "resource_type": "",
      "parameters": {
        "type": "object",
        "properties": {}
      },
      "execution": {
        "method": "POST",
        "path": "/team.info",
        "headers": {"Content-Type": "application/json; charset=utf-8"},
        "response_path": "team"
      },
      "response_schema": "team_info_response"
    },

    "auth_test": {
      "display_name": "Identity check",
      "description": "Verify the bot's authentication and return the bot's identity (user_id, team_id, team, url).",
      "access": "read",
      "resource_type": "",
      "parameters": {
        "type": "object",
        "properties": {}
      },
      "execution": {
        "method": "POST",
        "path": "/auth.test",
        "headers": {"Content-Type": "application/json; charset=utf-8"}
      },
      "response_schema": "auth_test_response"
    },

    "chat_post_message": {
      "display_name": "Post a message",
      "description": "Post a message to a channel, DM, or thread. Supply 'thread_ts' to post as a thread reply. Supports plain text and Block Kit blocks.",
      "access": "write",
      "resource_type": "slack_thread",
      "parameters": {
        "type": "object",
        "properties": {
          "channel": {"type": "string", "description": "Channel ID or name (#general)"},
          "text": {"type": "string", "description": "Fallback plain text; required unless blocks/attachments are set"},
          "thread_ts": {"type": "string", "description": "Parent thread timestamp to reply in a thread"},
          "blocks": {"type": "array", "description": "Block Kit blocks for rich formatting"},
          "attachments": {"type": "array", "description": "Legacy secondary attachments"},
          "mrkdwn": {"type": "boolean"},
          "reply_broadcast": {"type": "boolean", "description": "When set with thread_ts, also post to the channel"},
          "unfurl_links": {"type": "boolean"},
          "unfurl_media": {"type": "boolean"},
          "link_names": {"type": "boolean"},
          "parse": {"type": "string"},
          "username": {"type": "string"},
          "icon_emoji": {"type": "string"},
          "icon_url": {"type": "string"}
        },
        "required": ["channel"]
      },
      "execution": {
        "method": "POST",
        "path": "/chat.postMessage",
        "headers": {"Content-Type": "application/json; charset=utf-8"},
        "body_mapping": {
          "channel": "channel",
          "text": "text",
          "thread_ts": "thread_ts",
          "blocks": "blocks",
          "attachments": "attachments",
          "mrkdwn": "mrkdwn",
          "reply_broadcast": "reply_broadcast",
          "unfurl_links": "unfurl_links",
          "unfurl_media": "unfurl_media",
          "link_names": "link_names",
          "parse": "parse",
          "username": "username",
          "icon_emoji": "icon_emoji",
          "icon_url": "icon_url"
        }
      },
      "response_schema": "chat_post_message_response"
    },

    "chat_post_ephemeral": {
      "display_name": "Post ephemeral message",
      "description": "Post a message visible only to one specific user in a channel. Useful for bot replies that shouldn't clutter the channel for everyone.",
      "access": "write",
      "resource_type": "slack_thread",
      "parameters": {
        "type": "object",
        "properties": {
          "channel": {"type": "string"},
          "user": {"type": "string", "description": "Target user who will see this message"},
          "text": {"type": "string"},
          "thread_ts": {"type": "string"},
          "blocks": {"type": "array"},
          "attachments": {"type": "array"}
        },
        "required": ["channel", "user"]
      },
      "execution": {
        "method": "POST",
        "path": "/chat.postEphemeral",
        "headers": {"Content-Type": "application/json; charset=utf-8"},
        "body_mapping": {
          "channel": "channel",
          "user": "user",
          "text": "text",
          "thread_ts": "thread_ts",
          "blocks": "blocks",
          "attachments": "attachments"
        }
      },
      "response_schema": "chat_post_ephemeral_response"
    },

    "chat_update": {
      "display_name": "Update a message",
      "description": "Edit an already-posted message. 'ts' identifies the message; 'channel' is its channel.",
      "access": "write",
      "resource_type": "slack_thread",
      "parameters": {
        "type": "object",
        "properties": {
          "channel": {"type": "string"},
          "ts": {"type": "string", "description": "Timestamp of the message to edit"},
          "text": {"type": "string"},
          "blocks": {"type": "array"},
          "attachments": {"type": "array"},
          "link_names": {"type": "boolean"},
          "parse": {"type": "string"}
        },
        "required": ["channel", "ts"]
      },
      "execution": {
        "method": "POST",
        "path": "/chat.update",
        "headers": {"Content-Type": "application/json; charset=utf-8"},
        "body_mapping": {
          "channel": "channel",
          "ts": "ts",
          "text": "text",
          "blocks": "blocks",
          "attachments": "attachments",
          "link_names": "link_names",
          "parse": "parse"
        }
      },
      "response_schema": "chat_update_response"
    },

    "chat_delete": {
      "display_name": "Delete a message",
      "description": "Delete a previously-posted message.",
      "access": "write",
      "resource_type": "slack_thread",
      "parameters": {
        "type": "object",
        "properties": {
          "channel": {"type": "string"},
          "ts": {"type": "string"}
        },
        "required": ["channel", "ts"]
      },
      "execution": {
        "method": "POST",
        "path": "/chat.delete",
        "headers": {"Content-Type": "application/json; charset=utf-8"},
        "body_mapping": {
          "channel": "channel",
          "ts": "ts"
        }
      },
      "response_schema": "chat_delete_response"
    },

    "reactions_add": {
      "display_name": "Add emoji reaction",
      "description": "Add an emoji reaction to a message.",
      "access": "write",
      "resource_type": "",
      "parameters": {
        "type": "object",
        "properties": {
          "channel": {"type": "string"},
          "timestamp": {"type": "string"},
          "name": {"type": "string", "description": "Emoji name without colons, e.g. 'thumbsup'"}
        },
        "required": ["channel", "timestamp", "name"]
      },
      "execution": {
        "method": "POST",
        "path": "/reactions.add",
        "headers": {"Content-Type": "application/json; charset=utf-8"},
        "body_mapping": {
          "channel": "channel",
          "timestamp": "timestamp",
          "name": "name"
        }
      },
      "response_schema": "slack_ok_response"
    },

    "reactions_remove": {
      "display_name": "Remove emoji reaction",
      "description": "Remove an emoji reaction from a message.",
      "access": "write",
      "resource_type": "",
      "parameters": {
        "type": "object",
        "properties": {
          "channel": {"type": "string"},
          "timestamp": {"type": "string"},
          "name": {"type": "string"}
        },
        "required": ["channel", "timestamp", "name"]
      },
      "execution": {
        "method": "POST",
        "path": "/reactions.remove",
        "headers": {"Content-Type": "application/json; charset=utf-8"},
        "body_mapping": {
          "channel": "channel",
          "timestamp": "timestamp",
          "name": "name"
        }
      },
      "response_schema": "slack_ok_response"
    },

    "conversations_open": {
      "display_name": "Open DM",
      "description": "Open a direct message or multi-party DM channel. Pass 'users' as a comma-separated list of user IDs; for a 1:1 DM, pass a single user ID.",
      "access": "write",
      "resource_type": "slack_channel",
      "parameters": {
        "type": "object",
        "properties": {
          "users": {"type": "string", "description": "Comma-separated user IDs"},
          "channel": {"type": "string", "description": "Existing conversation to resume"},
          "return_im": {"type": "boolean"}
        }
      },
      "execution": {
        "method": "POST",
        "path": "/conversations.open",
        "headers": {"Content-Type": "application/json; charset=utf-8"},
        "body_mapping": {
          "users": "users",
          "channel": "channel",
          "return_im": "return_im"
        },
        "response_path": "channel"
      },
      "response_schema": "conversations_open_response"
    }
  },

  "schemas": {
    "conversations_history_response": {
      "type": "object",
      "properties": {
        "ok": {"type": "boolean"},
        "messages": {"type": "array", "description": "List of message objects"},
        "has_more": {"type": "boolean"},
        "response_metadata": {"type": "object", "description": "Contains next_cursor for pagination"}
      }
    },
    "conversations_replies_response": {
      "type": "object",
      "properties": {
        "ok": {"type": "boolean"},
        "messages": {"type": "array", "description": "Parent message followed by all thread replies"},
        "has_more": {"type": "boolean"},
        "response_metadata": {"type": "object"}
      }
    },
    "conversations_info_response": {
      "type": "object",
      "properties": {
        "ok": {"type": "boolean"},
        "channel": {"type": "object", "description": "Channel metadata: id, name, topic, purpose, created, creator, num_members, is_private, is_archived"}
      }
    },
    "conversations_list_response": {
      "type": "object",
      "properties": {
        "ok": {"type": "boolean"},
        "channels": {"type": "array"},
        "response_metadata": {"type": "object"}
      }
    },
    "conversations_members_response": {
      "type": "object",
      "properties": {
        "ok": {"type": "boolean"},
        "members": {"type": "array", "description": "List of user IDs"},
        "response_metadata": {"type": "object"}
      }
    },
    "users_info_response": {
      "type": "object",
      "properties": {
        "ok": {"type": "boolean"},
        "user": {"type": "object", "description": "User object: id, name, real_name, profile (email, display_name, title, image_*), tz, is_bot, is_admin"}
      }
    },
    "users_list_response": {
      "type": "object",
      "properties": {
        "ok": {"type": "boolean"},
        "members": {"type": "array"},
        "response_metadata": {"type": "object"}
      }
    },
    "search_messages_response": {
      "type": "object",
      "properties": {
        "ok": {"type": "boolean"},
        "query": {"type": "string"},
        "messages": {"type": "object", "description": "Contains total, pagination, matches (array of message objects with permalink)"}
      }
    },
    "reactions_get_response": {
      "type": "object",
      "properties": {
        "ok": {"type": "boolean"},
        "type": {"type": "string"},
        "channel": {"type": "string"},
        "message": {"type": "object", "description": "The message object including its reactions array"}
      }
    },
    "team_info_response": {
      "type": "object",
      "properties": {
        "ok": {"type": "boolean"},
        "team": {"type": "object", "description": "Team metadata: id, name, domain, email_domain, icon"}
      }
    },
    "auth_test_response": {
      "type": "object",
      "properties": {
        "ok": {"type": "boolean"},
        "url": {"type": "string"},
        "team": {"type": "string"},
        "user": {"type": "string"},
        "team_id": {"type": "string"},
        "user_id": {"type": "string"},
        "bot_id": {"type": "string"}
      }
    },
    "chat_post_message_response": {
      "type": "object",
      "properties": {
        "ok": {"type": "boolean"},
        "channel": {"type": "string"},
        "ts": {"type": "string", "description": "Timestamp of the posted message — use as thread_ts for follow-up replies in the same thread"},
        "message": {"type": "object"}
      }
    },
    "chat_post_ephemeral_response": {
      "type": "object",
      "properties": {
        "ok": {"type": "boolean"},
        "message_ts": {"type": "string"}
      }
    },
    "chat_update_response": {
      "type": "object",
      "properties": {
        "ok": {"type": "boolean"},
        "channel": {"type": "string"},
        "ts": {"type": "string"},
        "text": {"type": "string"}
      }
    },
    "chat_delete_response": {
      "type": "object",
      "properties": {
        "ok": {"type": "boolean"},
        "channel": {"type": "string"},
        "ts": {"type": "string"}
      }
    },
    "conversations_open_response": {
      "type": "object",
      "properties": {
        "ok": {"type": "boolean"},
        "no_op": {"type": "boolean", "description": "True when reopening an existing conversation"},
        "already_open": {"type": "boolean"},
        "channel": {"type": "object", "description": "The DM/group channel; channel.id is what you pass to chat.postMessage"}
      }
    },
    "slack_ok_response": {
      "type": "object",
      "properties": {
        "ok": {"type": "boolean"},
