# ==============================================================================
# Rust rag-engine dev/local env file.
#
# Copy this to `.env.rag` at the repo root and fill in real values.
# `.env.rag` is git-ignored (see .gitignore) — never commit real keys.
#
# Load via: `make rag-engine-dev` (the Makefile sources this file before
# starting the server).
# ==============================================================================

# ---- rag-engine server ----
RAG_ENGINE_LISTEN_ADDR=127.0.0.1:50651
RAG_ENGINE_SHARED_SECRET=localdev-secret-change-me
RAG_ENGINE_LOG_LEVEL=info
# Optional: Prometheus metrics endpoint. Default 0.0.0.0:9090.
# RAG_ENGINE_METRICS_ADDR=127.0.0.1:9090
# Optional: OTLP span export. Leave unset for logs-only.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ---- embedder (OpenAI-compatible) ----
# Provider switch: `openai_compat` uses any OpenAI-compat endpoint (OpenAI,
# OpenRouter, Groq, SiliconFlow, Together, Jina, etc.). `fake` is a
# deterministic in-process embedder for local testing and CI.
LLM_PROVIDER=openai_compat

# --- OpenAI text-embedding-3-large (default recommendation) ---
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=sk-REPLACE_ME
LLM_MODEL=text-embedding-3-large
LLM_EMBEDDING_DIM=3072
# OpenAI models don't use prefixes — empty string wins over auto-detect.
LLM_QUERY_PREFIX=
LLM_PASSAGE_PREFIX=
LLM_MAX_INPUT_TOKENS=8191
LLM_BATCH_SIZE=100
LLM_REQUEST_TIMEOUT_SECS=30
LLM_CONCURRENCY=4
LLM_MAX_RETRIES=3

# --- Alternative: SiliconFlow Qwen3-Embedding-4B (cheapest OSS tier) ---
# LLM_API_URL=https://api.siliconflow.cn/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=Qwen/Qwen3-Embedding-4B
# LLM_EMBEDDING_DIM=2560
# LLM_QUERY_PREFIX="query: "
# LLM_PASSAGE_PREFIX="passage: "

# --- Alternative: Groq / OpenRouter ---
# LLM_API_URL=https://api.groq.com/openai/v1
# LLM_API_URL=https://openrouter.ai/api/v1

# --- Alternative: fake (no network, deterministic) ---
# LLM_PROVIDER=fake
# LLM_EMBEDDING_DIM=2560
# Nothing else required when fake.

# ---- reranker ----
# `siliconflow` calls the real Qwen3-Reranker; `fake` is deterministic.
# Env prefix is RERANKER_ (NOT SILICONFLOW_). The reranker and embedder
# are independent — embedder uses LLM_*, reranker uses RERANKER_*.
RERANKER_KIND=fake
# RERANKER_API_URL=https://api.siliconflow.com/v1          # default; override for another OpenAI-compat rerank host
# RERANKER_API_KEY=sk-...
# RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B                  # or Qwen/Qwen3-Reranker-4B / 8B
# RERANKER_BATCH_SIZE=100
# RERANKER_TIMEOUT_SECS=10

# ---- LanceDB storage (R2 prod, MinIO dev) ----
# For local MinIO (docker-compose up minio):
LANCE_S3_URI=s3://hiveloop-rag-test/live-demo
LANCE_S3_ENDPOINT=http://localhost:9000
LANCE_S3_REGION=us-east-1
LANCE_ACCESS_KEY_ID=minioadmin
LANCE_SECRET_ACCESS_KEY=minioadmin
LANCE_S3_ALLOW_HTTP=true

# --- Alternative: Cloudflare R2 (prod) ---
# LANCE_S3_URI=s3://<bucket>/<prefix>
# LANCE_S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# LANCE_S3_REGION=auto
# LANCE_ACCESS_KEY_ID=<r2-access-key>
# LANCE_SECRET_ACCESS_KEY=<r2-secret-key>
# LANCE_S3_ALLOW_HTTP=false

# --- Alternative: local disk (zero infra, single-host only) ---
# Unset all LANCE_S3_* vars and the store defaults to ./.lancedb/
# (relative to the server's working directory).

# ---- misc ----
# Silence AWS SDK IMDS probe on macOS (saves ~5s on startup against MinIO).
AWS_EC2_METADATA_DISABLED=true
