# ==============================================================================
# RAG dev/local env file.
#
# Copy this to `.env.rag` at the repo root and fill in real values.
# `.env.rag` is git-ignored — never commit real keys.
#
# Load via: `make ragtest` (which runs the live e2e exerciser).
# ==============================================================================

# ---- Qdrant (self-hosted) ----
QDRANT_ENDPOINT=https://qdrant.example.com
QDRANT_API_KEY=
QDRANT_COLLECTION=rag_chunks_3072

# ---- embedder (OpenAI-compatible) ----
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=sk-REPLACE_ME
LLM_MODEL=text-embedding-3-large
LLM_EMBEDDING_DIM=3072

# ---- reranker (Cohere-compatible /rerank endpoint) ----
RERANKER_BASE_URL=https://openrouter.ai/api/v1
RERANKER_API_KEY=sk-REPLACE_ME
RERANKER_MODEL=cohere/rerank-v3.5

# ---- ingest tuning ----
RAG_BATCH_SIZE=100
