#!/bin/sh
set -eu

TOKEN="${HIVY_RUNTIME_SECRET:-}"
if [ -z "$TOKEN" ]; then
  echo "git-credential-hivy: missing HIVY_RUNTIME_SECRET" >&2
  exit 1
fi

: "${HIVY_GIT_CREDENTIALS_URL:?git-credential-hivy: missing HIVY_GIT_CREDENTIALS_URL}"

exec curl -fsS \
  -X POST \
  -H "Authorization: Bearer $TOKEN" \
  "$HIVY_GIT_CREDENTIALS_URL"
