#!/bin/sh
set -eu

TOKEN="${HIVY_RUNTIME_SECRET:-}"
if [ -z "$TOKEN" ]; then
  echo "gh-wrapper: missing HIVY_RUNTIME_SECRET" >&2
  exit 1
fi

: "${HIVY_GIT_CREDENTIALS_URL:?gh-wrapper: missing HIVY_GIT_CREDENTIALS_URL}"

cwd="$(pwd 2>/dev/null || printf '/')"
payload="$(
  python3 - "$cwd" "$@" <<'PY'
import json
import sys

json.dump(
    {
        "schema_version": 1,
        "client": "gh-wrapper",
        "operation": {
            "program": "gh",
            "argv": sys.argv[2:],
            "cwd": sys.argv[1],
        },
    },
    sys.stdout,
    separators=(",", ":"),
)
PY
)"

response_file="$(mktemp)"
cleanup() {
  rm -f "$response_file"
}
trap cleanup EXIT HUP INT TERM

status="$(
  curl -sS \
    -o "$response_file" \
    -w "%{http_code}" \
    -X POST \
    -H "Authorization: Bearer $TOKEN" \
    -H "Content-Type: application/json" \
    --data "$payload" \
    "$HIVY_GIT_CREDENTIALS_URL"
)" || {
  rc=$?
  echo "gh-wrapper: failed to request GitHub token from control plane" >&2
  exit "$rc"
}

case "$status" in
  2*) ;;
  *)
    echo "gh-wrapper: control plane rejected gh command ($status)" >&2
    cat "$response_file" >&2 || true
    echo >&2
    exit 1
    ;;
esac

GH_TOKEN="$(awk -F= '$1 == "password" {print substr($0, index($0, "=") + 1); exit}' "$response_file" | tr -d '\r')"
if [ -z "$GH_TOKEN" ]; then
  echo "gh-wrapper: credential response did not include a password" >&2
  exit 1
fi

export GH_NO_KEYRING=1
export GH_TOKEN

cleanup
trap - EXIT HUP INT TERM
exec /usr/bin/gh "$@"
