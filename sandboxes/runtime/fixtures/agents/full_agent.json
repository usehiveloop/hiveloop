{
  "id": "agent_full",
  "name": "Full Agent",
  "system_prompt": "You are a coding assistant.",
  "provider": {
    "provider_type": "open_ai",
    "model": "gpt-4o",
    "api_key": "test-key-full",
    "base_url": "https://api.openai.com/v1"
  },
  "tools": [
    {
      "name": "calculator",
      "description": "Performs basic arithmetic operations.",
      "parameters_schema": {
        "type": "object",
        "properties": {
          "operation": {
            "type": "string",
            "enum": ["add", "subtract", "multiply", "divide"],
            "description": "The arithmetic operation to perform."
          },
          "a": {
            "type": "number",
            "description": "The first operand."
          },
          "b": {
            "type": "number",
            "description": "The second operand."
          }
        },
        "required": ["operation", "a", "b"]
      }
    }
  ],
  "mcp_servers": [
    {
      "name": "filesystem",
      "transport": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp/workspace"],
        "env": {
          "NODE_ENV": "test"
        }
      }
    }
  ],
  "skills": [
    {
      "id": "skill_code_review",
      "title": "Code Review",
      "description": "Reviews code for quality, bugs, and best practices.",
      "content": "You are a code review expert. Review code for quality, bugs, and best practices."
    },
    {
      "id": "skill_deploy",
      "title": "Deploy",
      "description": "Deploy the application to production with safety checks.",
      "content": "You are a deployment expert.\n\nFor detailed runbook, see [runbook.md](runbook.md).\nFor environment config, see [envs.md](envs.md).\n\nDeploy using: $ARGUMENTS",
      "files": {
        "runbook.md": "# Deploy Runbook\n\n1. Run tests\n2. Build artifacts\n3. Push to registry\n4. Rolling update",
        "envs.md": "# Environments\n\n- staging: deploy-staging.example.com\n- production: deploy-prod.example.com"
      },
      "frontmatter": {
        "allowed_tools": ["bash", "read"],
        "effort": "high",
        "context": "fork",
        "argument_hint": "[environment]"
      },
      "source": "control_plane"
    }
  ],
  "permissions": {
    "bash": "require_approval",
    "write": "require_approval",
    "calculator": "allow"
  },
  "config": {
    "max_tokens": 4096,
    "max_turns": 10,
    "temperature": 0.7,
    "tool_calls_only": false
  },
  "subagents": [],
  "webhook_url": "https://example.com/webhooks/agent",
  "webhook_secret": "<webhook-secret>"
}
