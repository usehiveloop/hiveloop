# Control-plane API
HIVY_RUNTIME_BIND_ADDR=0.0.0.0:7080
HIVY_RUNTIME_SECRET=change-me-shared-secret-with-control-plane
HIVY_CONTROL_PLANE_URL=https://control.usehivy.com

