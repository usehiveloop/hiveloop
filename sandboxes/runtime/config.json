{
  "agent": {
    "name": "Aria",
    "description": "Hivy AI employee",
    "system_prompt": "You are Aria, a friendly AI assistant. Reply concisely (<= 3 short sentences). Never invent features. If you don't know something, say so.\n\nMCP tools are lazy-loaded. Call load_tools(tool_names=[...]) with ALL tools you need in ONE call. Loaded tools appear on the next response.\n\nSkills are procedural memory stored in /workspace/.skills. Use skills_list to discover available skills. Use skill_view only when a skill is relevant to the current task. Do not load all skills. When skill_view shows linked files, load only the specific linked file needed. Use skill_manage only when the user asks to create/update/delete a skill, or after asking permission to remember a workflow."
  },
  "model": {
    "provider": "openai_compatible",
    "base_url": "http://127.0.0.1:7081/api/v1",
    "model_id": "deepseek/deepseek-v4-flash",
    "api_key_env": "OPENROUTER_API_KEY",
    "temperature": 0.3,
    "max_output_tokens": 1024,
    "reasoning_effort": "low",
    "extra_headers": {},
    "fallback": null
  },
  "multimodal_model": {
    "provider": "openai_compatible",
    "base_url": "http://127.0.0.1:7081/api/v1",
    "model_id": "google/gemini-3-flash-preview",
    "api_key_env": "OPENROUTER_API_KEY",
    "temperature": 0.3,
    "max_output_tokens": 1024,
    "reasoning_effort": "low",
    "extra_headers": {},
    "fallback": null
  },
  "limits": {
    "max_turns_per_session": 50,
    "input_token_budget": 180000,
    "output_token_budget": 8000,
    "tool_call_timeout_seconds": 60,
    "subagent_max_depth": 2
  },
  "context": {
    "max_history_events": null,
    "compaction": {
      "enabled": true,
      "token_threshold": 90000,
      "overlap_event_count": 10,
      "chars_per_token": 4,
      "summarizer_model": {
        "provider": "openai_compatible",
        "base_url": "http://127.0.0.1:7081/api/v1",
        "model_id": "deepseek/deepseek-v4-flash",
        "api_key_env": "OPENROUTER_API_KEY",
        "temperature": 0.3,
        "max_output_tokens": 1024,
        "reasoning_effort": "low",
        "extra_headers": {},
        "fallback": null
      }
    }
  },
  "tools": [
    {
      "type": "builtin.bash",
      "config": {
        "workdir": ".",
        "timeout_seconds": 60,
        "max_output_bytes": 5242880,
        "deny_patterns": [
          "rm -rf /",
          "rm -rf ~",
          "mkfs",
          "dd if=",
          ":(){:|:&};:",
          "shutdown",
          "reboot"
        ],
        "env_passthrough": [
          "HOME",
          "PATH",
          "LANG",
          "LC_ALL"
        ],
        "sandbox": "process_isolated"
      }
    },
    {
      "type": "builtin.read_file",
      "config": {
        "allowed_roots": [],
        "max_file_size_bytes": 5242880,
        "deny_globs": [
          "**/.env",
          "**/.env.*",
          "**/secrets/**",
          "**/id_rsa*",
          "**/*.pem"
        ]
      }
    },
    {
      "type": "builtin.write_file",
      "config": {
        "allowed_roots": [],
        "max_file_size_bytes": 5242880,
        "deny_globs": [
          "**/.env",
          "**/.env.*",
          "**/secrets/**",
          "**/.git/**",
          "**/node_modules/**"
        ],
        "atomic": true
      }
    },
    {
      "type": "builtin.cron"
    },
    {
      "type": "builtin.delegate"
    },
    {
      "type": "builtin.check_delegated_status"
    },
    {
      "type": "builtin.check_bash_status"
    },
    {
      "type": "builtin.wake"
    },
    {
      "type": "builtin.load_tools"
    },
    {
      "type": "builtin.skills_list"
    },
    {
      "type": "builtin.skill_view"
    },
    {
      "type": "builtin.skill_manage"
    }
  ],
  "mcp_servers": [],
  "skills": [],
  "subagents": [],
  "outbound_channels": []
}
