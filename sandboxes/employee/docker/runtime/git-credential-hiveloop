#!/bin/sh
set -eu

TOKEN="${BRIDGE_CONTROL_PLANE_API_KEY:-${BRIDGE_API_KEY:-${RUNTIME_SECRET:-}}}"
if [ -z "$TOKEN" ]; then
  echo "git-credential-hiveloop: missing bridge API token" >&2
  exit 1
fi

: "${HIVELOOP_GIT_CREDENTIALS_URL:?git-credential-hiveloop: missing HIVELOOP_GIT_CREDENTIALS_URL}"

exec curl -fsS \
  -X POST \
  -H "Authorization: Bearer $TOKEN" \
  "$HIVELOOP_GIT_CREDENTIALS_URL"
