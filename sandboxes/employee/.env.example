# Slack credentials (Socket Mode)
SLACK_BOT_TOKEN=<slack-bot-token>
SLACK_APP_TOKEN=<slack-app-token>

# Control-plane API
RUNTIME_BIND_ADDR=0.0.0.0:7080
RUNTIME_SECRET=change-me-shared-secret-with-control-plane

# Bootstrap config source (one of)
CONTROL_PLANE_URL=https://control.hiveloop.com
INITIAL_CONFIG_FILE=./config.json

# Webhook outbound delivery
WEBHOOK_URL=https://control.hiveloop.com/runtimes/aria-prod/events
WEBHOOK_SECRET=change-me-webhook-hmac-secret

# Storage
DB_PATH=./data/employee-bridge.db

# Model providers (referenced by AgentDefinition.model.api_key_env)
OPENAI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=

# Logging
RUST_LOG=info,employee_bridge=debug
