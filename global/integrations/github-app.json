{
  "version": 1,
  "id": "github-app",
  "provider": "github-app",
  "nango_provider": "github-app",
  "unique_key": "github-app",
  "display_name": "GitHub",
  "enabled": true,
  "required": false,
  "supports_rag_source": true,
  "credentials": {
    "type": "APP",
    "app_id_env": "HIVY_NANGO_GITHUB_APP_ID",
    "app_link_env": "HIVY_NANGO_GITHUB_APP_LINK",
    "private_key_env": "HIVY_NANGO_GITHUB_APP_PRIVATE_KEY",
    "webhook_secret_env": "HIVY_NANGO_GITHUB_APP_WEBHOOK_SECRET"
  }
}
