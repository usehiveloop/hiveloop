{
  "name": "@usehivy/emails",
  "private": true,
  "scripts": {
    "dev": "email dev --dir emails --port 30113",
    "dev:resend": "HIVY_EMAIL_RENDER_TARGET=resend email dev --dir emails --port 30113",
    "export": "email export --dir emails --outDir dist",
    "upload:resend": "tsx scripts/upload-resend-templates.ts",
    "upload:resend:dry": "tsx scripts/upload-resend-templates.ts --dry-run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-email": "^5.1.0",
    "resend": "^6.9.2"
  },
  "devDependencies": {
    "@react-email/preview-server": "5.2.11",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
