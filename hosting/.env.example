# =============================================================================
# LLMVault — Production Environment Variables
# =============================================================================
# Copy to .env and fill in all values before running:
#   docker compose -f docker-compose.production.yml up -d
# =============================================================================

# ── Domains (used by Caddy for TLS and routing) ───────────────────────────
API_DOMAIN=api.example.com
MCP_DOMAIN=mcp.example.com
APP_DOMAIN=app.example.com
CONNECT_DOMAIN=connect.example.com
NANGO_DOMAIN=integrations.example.com
ACME_EMAIL=admin@example.com

# ── Environment ───────────────────────────────────────────────────────────
HIVY_ENVIRONMENT=production

# ── Server ────────────────────────────────────────────────────────────────
HIVY_PORT=8080
HIVY_LOG_LEVEL=info
HIVY_LOG_FORMAT=json

# ── PostgreSQL (shared by API + Nango) ────────────────────────────────────
HIVY_DB_HOST=postgres
HIVY_DB_PORT=5432
HIVY_DB_USER=llmvault
HIVY_DB_PASSWORD=                             # REQUIRED: strong random password
HIVY_DB_NAME=llmvault
HIVY_DB_SSLMODE=disable                       # internal Docker network

# ── Redis ─────────────────────────────────────────────────────────────────
HIVY_REDIS_ADDR=redis:6379
HIVY_REDIS_PASSWORD=                          # REQUIRED: strong random password
HIVY_REDIS_DB=0
HIVY_REDIS_CACHE_TTL=30m

# ── L1 Cache (in-memory) ─────────────────────────────────────────────────
HIVY_MEM_CACHE_TTL=5m
HIVY_MEM_CACHE_MAX_SIZE=10000

# ── KMS (key wrapping for credential encryption) ─────────────────────────
# Use "aead" for single-node deployments (base64-encoded 32-byte key).
# Use "awskms" for AWS KMS or "vault" for HashiCorp Vault in multi-node.
HIVY_KMS_TYPE=aead
HIVY_KMS_KEY=                                 # REQUIRED: base64-encoded 32-byte key
                                         #   generate with: openssl rand -base64 32

# For AWS KMS:
# HIVY_KMS_TYPE=awskms
# HIVY_KMS_KEY=arn:aws:kms:us-east-1:123456789:key/your-key-id
# HIVY_AWS_REGION=us-east-1
# HIVY_AWS_ACCESS_KEY_ID=
# HIVY_AWS_SECRET_ACCESS_KEY=

# ── Auth (embedded JWT/RSA) ──────────────────────────────────────────────
# Generate with: openssl genrsa 2048 | base64 | tr -d '\n'
HIVY_AUTH_RSA_PRIVATE_KEY=                    # REQUIRED: base64-encoded RSA private key PEM
HIVY_AUTH_ISSUER=llmvault
HIVY_AUTH_AUDIENCE=https://api.example.com    # should match API_DOMAIN
HIVY_AUTH_ACCESS_TOKEN_TTL=15m
HIVY_AUTH_REFRESH_TOKEN_TTL=720h
HIVY_AUTO_CONFIRM_EMAIL=false

# ── JWT ───────────────────────────────────────────────────────────────────
HIVY_JWT_SIGNING_KEY=                         # REQUIRED: strong random secret
                                         #   generate with: openssl rand -base64 32

# ── MCP ───────────────────────────────────────────────────────────────────
HIVY_MCP_PORT=8081
HIVY_MCP_BASE_URL=https://mcp.example.com     # should match MCP_DOMAIN

# ── CORS ──────────────────────────────────────────────────────────────────
HIVY_CORS_ORIGINS=https://app.example.com,https://connect.example.com
HIVY_FRONTEND_URL=https://app.example.com

# ── Nango (OAuth integration proxy) ──────────────────────────────────────
HIVY_NANGO_ENDPOINT=https://integrations.example.com
HIVY_NANGO_SECRET_KEY=                        # REQUIRED: Nango secret key (UUID v4)
HIVY_NANGO_ENCRYPTION_KEY=                    # REQUIRED: 32-byte base64 key for Nango
                                         #   generate with: openssl rand -base64 32
HIVY_NANGO_DASHBOARD_USERNAME=                # REQUIRED: Nango admin dashboard username
HIVY_NANGO_DASHBOARD_PASSWORD=                # REQUIRED: Nango admin dashboard password

# ── Sandbox / Agent (optional) ────────────────────────────────────────────
# HIVY_SANDBOX_ENCRYPTION_KEY=                # base64-encoded 32-byte key
# HIVY_DAYTONA_API_URL=https://app.daytona.io/api
# HIVY_DAYTONA_API_KEY=
# HIVY_DAYTONA_TARGET=eu
# HIVY_CLOUD_AGENTS_SANDBOX_HOST=
# HIVY_CLOUD_AGENTS_SANDBOX_BASE_IMAGE_PREFIX=llmvault-bridge-0-10-0-small-v2
