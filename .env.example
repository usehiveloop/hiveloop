# =============================================================================
# LLMVault / llmvault — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Variables marked [required] will cause docker compose to fail if missing.
# =============================================================================

# --- Server ---
PORT=8080
LOG_LEVEL=info            # debug, info, warn, error
LOG_FORMAT=json           # json, text

# --- PostgreSQL [required] ---
POSTGRES_USER=proxybridge
POSTGRES_PASSWORD=         # [required] set a strong password
POSTGRES_DB=proxybridge
POSTGRES_PORT=5433         # host port mapped to container 5432

# --- Vault [required] ---
VAULT_TOKEN=               # [required] Vault root/app token
VAULT_KEY_NAME=proxy-bridge-master

# --- Redis ---
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=30m

# --- L1 Cache (in-memory) ---
MEM_CACHE_TTL=5m
MEM_CACHE_MAX_SIZE=10000

# --- JWT [required] ---
JWT_SIGNING_KEY=           # [required] HMAC-SHA256 signing key for sandbox tokens

# --- ZITADEL [required] ---
ZITADEL_MASTERKEY=         # [required] must be exactly 32 characters
ZITADEL_DB_PASSWORD=       # [required] password for the zitadel Postgres user
ZITADEL_EXTERNALDOMAIN=localhost
ZITADEL_EXTERNALPORT=8085

# --- ZITADEL client (auto-populated by zitadel-init, or set manually) ---
ZITADEL_CLIENT_ID=
ZITADEL_CLIENT_SECRET=

# --- E2E test keys (only needed for e2e tests) ---
# OPENROUTER_API_KEY=sk-or-...
# FIREWORKS_API_KEY=fw_...
