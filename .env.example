# Server
PORT=8080

# PostgreSQL
DATABASE_URL=postgres://proxybridge:localdev@localhost:5432/proxybridge?sslmode=disable

# Vault
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-token
VAULT_KEY_NAME=proxy-bridge-master

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=30m

# L1 Cache (in-memory)
MEM_CACHE_TTL=5m
MEM_CACHE_MAX_SIZE=10000

# JWT
JWT_SIGNING_KEY=change-me-in-production

# Admin
ADMIN_API_KEY=change-me-in-production

# E2E test keys (only needed for e2e tests)
# E2E_ANTHROPIC_KEY=sk-ant-...
# E2E_OPENAI_KEY=sk-...
# E2E_OPENROUTER_KEY=sk-or-...
# E2E_FIREWORKS_KEY=fw_...
# E2E_GEMINI_KEY=AIza...
