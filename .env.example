# =============================================================================
# Hivy local development environment
# =============================================================================
# Copy this file to `.env`, fill every required blank value, then run `make dev`.
# Docker Compose is the source of truth for local development.

# =============================================================================
# 1. Docker Compose host ports and images
# =============================================================================
HIVY_COMPOSE_API_PORT=8080
HIVY_COMPOSE_MCP_PORT=8081
HIVY_COMPOSE_WEB_PORT=30112
HIVY_COMPOSE_WORKER_HEALTH_PORT=8090
HIVY_COMPOSE_POSTGRES_PORT=15432
HIVY_COMPOSE_REDIS_PORT=16379
HIVY_COMPOSE_NANGO_PORT=23003
HIVY_COMPOSE_QDRANT_HTTP_PORT=6333
HIVY_COMPOSE_QDRANT_GRPC_PORT=6334
HIVY_COMPOSE_HINDSIGHT_API_PORT=8888
HIVY_COMPOSE_HINDSIGHT_IMAGE=ghcr.io/vectorize-io/hindsight:latest-slim
HIVY_RESEND_API_KEY=

# =============================================================================
# 2. Hivy backend process: runtime, HTTP, auth, and admin
# =============================================================================
HIVY_ENVIRONMENT=development
HIVY_PORT=8080
HIVY_LOG_LEVEL=info
HIVY_LOG_FORMAT=text
HIVY_FRONTEND_URL=http://localhost:30112
HIVY_CORS_ORIGINS=http://localhost:30112
HIVY_MCP_PORT=8081
HIVY_MCP_BASE_URL=http://localhost:8081
HIVY_API_WEBHOOK_BASE_URL=http://host.docker.internal:8080
HIVY_PROXY_HOST=localhost:8080
HIVY_AUTO_CONFIRM_EMAIL=true
HIVY_PLATFORM_ADMIN_EMAILS=agent-test@example.com

HIVY_SESSION_SECRET=
HIVY_JWT_SIGNING_KEY=
HIVY_AUTH_RSA_PRIVATE_KEY=
HIVY_AUTH_ISSUER=hivy
HIVY_AUTH_AUDIENCE=http://localhost:8080
HIVY_AUTH_ACCESS_TOKEN_TTL=15m
HIVY_AUTH_REFRESH_TOKEN_TTL=720h

HIVY_KMS_TYPE=aead
HIVY_KMS_KEY=
HIVY_AWS_REGION=

# =============================================================================
# 3. Hivy backend process: database, Redis, cache, and worker tuning
# =============================================================================
HIVY_DATABASE_URL=postgres://hivy:localdev@postgres:5432/hivy?sslmode=disable
HIVY_DB_HOST=postgres
HIVY_DB_PORT=5432
HIVY_DB_USER=hivy
HIVY_DB_PASSWORD=localdev
HIVY_DB_NAME=hivy
HIVY_DB_SSLMODE=disable

HIVY_REDIS_URL=
HIVY_REDIS_ADDR=redis:6379
HIVY_REDIS_PASSWORD=
HIVY_REDIS_DB=0
HIVY_REDIS_CACHE_TTL=30m
HIVY_MEM_CACHE_TTL=5m
HIVY_MEM_CACHE_MAX_SIZE=10000

HIVY_ASYNQ_CONCURRENCY=30
HIVY_ASYNQ_SHUTDOWN_TIMEOUT=120s
HIVY_WORKER_HEALTH_PORT=8090

# =============================================================================
# 4. Nango service and Hivy integration catalog credentials
# =============================================================================
# Hivy uses HIVY_NANGO_ENDPOINT / HIVY_NANGO_SECRET_KEY to call Nango.
# The Nango container consumes the other HIVY_NANGO_* values through Compose.
HIVY_NANGO_ENDPOINT=http://nango:3003
HIVY_NANGO_PUBLIC_URL=http://localhost:23003
HIVY_NANGO_SECRET_KEY=00000000-0000-4000-8000-000000000001
HIVY_NANGO_ENCRYPTION_KEY=
HIVY_NANGO_DASHBOARD_USERNAME=local
HIVY_NANGO_DASHBOARD_PASSWORD=local

HIVY_NANGO_GITHUB_APP_ID=
HIVY_NANGO_GITHUB_APP_LINK=
HIVY_NANGO_GITHUB_APP_PRIVATE_KEY=
HIVY_NANGO_GITHUB_APP_WEBHOOK_SECRET=
HIVY_NANGO_GITHUB_CODE_REVIEWS_APP_ID=
HIVY_NANGO_GITHUB_CODE_REVIEWS_APP_LINK=
HIVY_NANGO_GITHUB_CODE_REVIEWS_APP_PRIVATE_KEY=
HIVY_NANGO_GITHUB_CODE_REVIEWS_APP_WEBHOOK_SECRET=
HIVY_NANGO_LINEAR_CLIENT_ID=
HIVY_NANGO_LINEAR_CLIENT_SECRET=
HIVY_NANGO_LINEAR_WEBHOOK_SECRET=
HIVY_NANGO_NOTION_CLIENT_ID=
HIVY_NANGO_NOTION_CLIENT_SECRET=
HIVY_NANGO_NOTION_WEBHOOK_SECRET=
HIVY_NANGO_RAILWAY_CLIENT_ID=
HIVY_NANGO_RAILWAY_CLIENT_SECRET=
HIVY_NANGO_SLACK_CLIENT_ID=
HIVY_NANGO_SLACK_CLIENT_SECRET=

# =============================================================================
# 5. Sandbox orchestration: generic settings and provider selection
# =============================================================================
HIVY_SANDBOX_PROVIDER_ID=docker
HIVY_SANDBOX_ENCRYPTION_KEY=
HIVY_SANDBOX_RESOURCE_CHECK_INTERVAL=30m

HIVY_CLOUD_AGENTS_SANDBOX_RUNTIME_VERSION=v1.0.3
HIVY_CLOUD_AGENTS_SANDBOX_BASE_IMAGE_PREFIX=ghcr.io/usehivy/sandbox-bridge:v1.0.3
HIVY_CLOUD_AGENTS_SANDBOX_HOST=
HIVY_CLOUD_AGENT_SANDBOX_GRACE_PERIOD_MINS=5
HIVY_EMPLOYEE_SANDBOX_BASE_IMAGE_PREFIX=ghcr.io/usehivy/employee-sandbox:latest
HIVY_EMPLOYEE_SQLITE_BACKUP_MAX_BYTES=5368709120

# Docker sandbox provider. Required when HIVY_SANDBOX_PROVIDER_ID=docker.
HIVY_SANDBOX_DOCKER_HOST=unix:///var/run/docker.sock
HIVY_SANDBOX_DOCKER_PUBLIC_HOST=host.docker.internal
HIVY_SANDBOX_DOCKER_CONTAINER_LABEL_PREFIX=hivy

# Daytona sandbox provider. Required only when HIVY_SANDBOX_PROVIDER_ID=daytona.
HIVY_DAYTONA_API_URL=
HIVY_DAYTONA_API_KEY=
HIVY_DAYTONA_TARGET=

# =============================================================================
# 6. Hivy storage: private drive and public uploads
# =============================================================================
HIVY_AWS_S3_BUCKET_NAME=hivy-rag-test
HIVY_AWS_DEFAULT_REGION=us-east-1
HIVY_AWS_ENDPOINT_URL=http://minio:9000
HIVY_AWS_ACCESS_KEY_ID=minioadmin
HIVY_AWS_SECRET_ACCESS_KEY=minioadmin

HIVY_PUBLIC_ASSETS_S3_BUCKET=public-files-test
HIVY_PUBLIC_ASSETS_S3_REGION=us-east-1
HIVY_PUBLIC_ASSETS_S3_ENDPOINT=http://minio:9000
HIVY_PUBLIC_ASSETS_ACCESS_KEY_ID=minioadmin
HIVY_PUBLIC_ASSETS_SECRET_ACCESS_KEY=minioadmin
HIVY_PUBLIC_ASSETS_BASE_URL=http://localhost:9000/public-files-test
HIVY_PUBLIC_ASSETS_SIGN_TTL=15m
HIVY_PUBLIC_ASSETS_USE_ACL=false

# =============================================================================
# 7. Hivy RAG, search, and memory client configuration
# =============================================================================
HIVY_QDRANT_HOST=qdrant
HIVY_QDRANT_PORT=6334
HIVY_QDRANT_USE_TLS=false
HIVY_QDRANT_API_KEY=
HIVY_QDRANT_COLLECTION=rag_chunks_3072
HIVY_RAG_BATCH_SIZE=100

HIVY_LLM_API_URL=
HIVY_LLM_API_KEY=
HIVY_LLM_MODEL=
HIVY_LLM_EMBEDDING_DIM=3072

HIVY_RERANKER_BASE_URL=
HIVY_RERANKER_API_KEY=
HIVY_RERANKER_MODEL=

HIVY_HINDSIGHT_API_URL=http://hindsight:8888

# =============================================================================
# 8. Hindsight container runtime
# =============================================================================
# These values are consumed by the Hindsight container, not by the Hivy Go
# process. Local dev mirrors production and requires real provider keys.
HINDSIGHT_API_HOST=0.0.0.0
HINDSIGHT_API_PORT=8888
HINDSIGHT_API_DATABASE_SCHEMA=hindsight
HINDSIGHT_API_RUN_MIGRATIONS_ON_STARTUP=true
HINDSIGHT_API_WORKERS=2
HINDSIGHT_API_WORKER_ENABLED=true
HINDSIGHT_API_LOG_LEVEL=info
HINDSIGHT_API_LOG_FORMAT=json

HINDSIGHT_API_LLM_PROVIDER=openai
HINDSIGHT_API_LLM_BASE_URL=https://openrouter.ai/api/v1
HINDSIGHT_API_LLM_API_KEY=
HINDSIGHT_API_LLM_MODEL=google/gemini-2.5-flash

HINDSIGHT_API_CONSOLIDATION_LLM_PROVIDER=openrouter
HINDSIGHT_API_CONSOLIDATION_LLM_API_KEY=
HINDSIGHT_API_CONSOLIDATION_LLM_MODEL=openai/gpt-oss-20b

HINDSIGHT_API_REFLECT_LLM_PROVIDER=openrouter
HINDSIGHT_API_REFLECT_LLM_API_KEY=
HINDSIGHT_API_REFLECT_LLM_MODEL=openai/gpt-oss-20b

HINDSIGHT_API_RETAIN_LLM_PROVIDER=openrouter
HINDSIGHT_API_RETAIN_LLM_API_KEY=
HINDSIGHT_API_RETAIN_LLM_MODEL=openai/gpt-oss-20b

HINDSIGHT_API_EMBEDDINGS_PROVIDER=openai
HINDSIGHT_API_EMBEDDINGS_OPENAI_API_KEY=
HINDSIGHT_API_EMBEDDINGS_OPENAI_MODEL=text-embedding-3-small

HINDSIGHT_API_RERANKER_PROVIDER=zeroentropy
HINDSIGHT_API_RERANKER_ZEROENTROPY_API_KEY=
HINDSIGHT_API_RERANKER_ZEROENTROPY_MODEL=zerank-2

# =============================================================================
# 9. Web app runtime and browser-exposed values
# =============================================================================
HIVY_API_URL=http://api:8080
NEXT_PUBLIC_HIVY_API_URL=http://localhost:8080
NEXT_PUBLIC_HIVY_CONNECTIONS_HOST=http://localhost:23003

# =============================================================================
# 10. Observability
# =============================================================================
HIVY_SENTRY_ENABLED=false
HIVY_SENTRY_DSN=
NEXT_PUBLIC_HIVY_SENTRY_DSN=
HIVY_SENTRY_RELEASE=
HIVY_SENTRY_TRACES_SAMPLE_RATE=0
NEXT_PUBLIC_HIVY_SENTRY_TRACES_SAMPLE_RATE=0
HIVY_SENTRY_PROFILES_SAMPLE_RATE=0
HIVY_EMPLOYEE_SANDBOX_SENTRY_DSN=
HIVY_AGENT_SANDBOX_SENTRY_DSN=

# =============================================================================
# 11. Optional Hivy product integrations
# =============================================================================
HIVY_KIBAMAIL_API_KEY=
HIVY_KIBAMAIL_FROM_ADDRESS=betty@notifications.usehivy.com
HIVY_KIBAMAIL_FROM_NAME=Betty from Hivy

HIVY_OAUTH_GITHUB_CLIENT_ID=
HIVY_OAUTH_GITHUB_CLIENT_SECRET=
HIVY_OAUTH_GOOGLE_CLIENT_ID=
HIVY_OAUTH_GOOGLE_CLIENT_SECRET=
HIVY_OAUTH_X_CLIENT_ID=
HIVY_OAUTH_X_CLIENT_SECRET=

HIVY_SLACK_APP_TOKEN=
HIVY_GITHUB_TOKEN=
HIVY_SPIDER_CLOUD_API_KEY=
HIVY_SPIDER_BASE_URL=https://api.spider.cloud
HIVY_PAYSTACK_SECRET_KEY=

# =============================================================================
# 12. Optional custom preview domains
# =============================================================================
HIVY_PREVIEW_CNAME_TARGET=preview-proxy.usehivy.com
HIVY_INTERNAL_DOMAIN_SECRET=
HIVY_ACME_DNS_API_URL=
HIVY_CADDY_ADMIN_URL=

# =============================================================================
# 13. Optional seeded system LLM credentials
# =============================================================================
HIVY_SYSTEM_OPENAI_API_KEY=
HIVY_SYSTEM_ANTHROPIC_API_KEY=
HIVY_SYSTEM_GOOGLE_API_KEY=
HIVY_SYSTEM_OPENROUTER_API_KEY=
HIVY_SYSTEM_MOONSHOT_API_KEY=
